# ═══════════════════════════════════════════════════════════════
# 🐳 KAFKA — Local KRaft (Default)
# ═══════════════════════════════════════════════════════════════
# Par défaut, les services utilisent le broker Kafka local
# défini dans docker-compose.yml (service "kafka").
#
# Pour utiliser Aiven Cloud Kafka, commente les lignes ci-dessous
# et décommente la section "☁️ AIVEN CLOUD" plus bas (ou crée un
# fichier .env.aiven séparé).
#
#   docker compose --profile full up -d   ← local (par défaut)
#   docker compose --env-file .env.aiven --profile full up -d   ← Aiven

KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL_CA=
KAFKA_SSL_CERT=
KAFKA_SSL_KEY=

# ☁️ AIVEN CLOUD — décommente pour utiliser le cloud
# KAFKA_HOST=kafka-4238954-kafka-2c1f.h.aivencloud.com
# KAFKA_PORT=17498
# KAFKA_USERNAME=avnadmin
# KAFKA_PASSWORD=ton-mot-de-passe
# KAFKA_SSL_CA=certs/ca.pem
# KAFKA_SSL_CERT=certs/service.cert
# KAFKA_SSL_KEY=certs/service.key

# ═══════════════════════════════════════════════════════════════
# 📊 KAFKA TOPICS
# ═══════════════════════════════════════════════════════════════
KAFKA_TOPIC_INPUT=flux_data
KAFKA_TOPIC_OUTPUT=traffic_predictions

# ═══════════════════════════════════════════════════════════════
# 🔌 API BACKEND
# ═══════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ═══════════════════════════════════════════════════════════════
# ⚡ SPARK — Optimisé pour économie de ressources
# ═══════════════════════════════════════════════════════════════
# Container-internal paths (models mounted at /app/models)
MODEL_PATH=models/gnn_model.pth
SPARK_EXECUTOR_MEMORY=1g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_CORES=2
SPARK_SHUFFLE_PARTITIONS=4

# ═══════════════════════════════════════════════════════════════
# 📂 DATA & STREAMING
# ═══════════════════════════════════════════════════════════════
# Container-internal path (data mounted at /app/data)
CSV_PATH=data/test_gnn.csv
STREAM_DELAY=2.0
