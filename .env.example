# 🚀 Road Flow — Local Docker Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Par défaut, cette configuration est optimisée pour le lancement via Docker.
# Si vous utilisez un service externe (ex: Aiven), modifiez ces valeurs.

# 📦 Kafka Configuration
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL_CA=
KAFKA_SSL_CERT=
KAFKA_SSL_KEY=

# 🎯 Topics Kafka
KAFKA_TOPIC_INPUT=flux_data
KAFKA_TOPIC_OUTPUT=traffic_predictions

# 🌐 API Backend Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ⚡ Spark Configuration
MODEL_PATH=/app/models/global_model.pt
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=2g

# 📊 Data Paths
CSV_PATH=/app/data/test.csv
STREAM_DELAY=1.0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 💡 Note pour Aiven Kafka :
# Si vous voulez utiliser Aiven, remplacez KAFKA_HOST par votre endpoint,
# ajoutez vos credentials et pointez KAFKA_SSL_CA vers /app/certs/ca.pem
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
